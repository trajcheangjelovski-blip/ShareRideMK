# Копирај го овој фајл во .env.local и пополни ги вистинските вредности.
# .env.local е игнориран од git — вистинските клучеви НИКОГАШ не се коммитираат.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose

# Maps (Mapbox or Google)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
